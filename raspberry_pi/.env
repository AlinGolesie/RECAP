# fill in your values before running the script

# this is the firebase user ID - you can find it in firebase console under authentication -> users
# the device will add points to this account when it scans a bottle
RECAP_USER_ID=rAFkj2G107UwNqFSdZWCQCZtR2q1

# put the IP address of the machine running the backend here (has to be on the same network)
RECAP_BACKEND_URL=http://192.168.1.236:3000

# path to the .eim model file exported from edge impulse (linux aarch64 version)
EIM_MODEL_PATH=./recap-linux-aarch64-v5-impulse-#2.eim

# just a name to identify this raspberry pi in the logs
DEVICE_ID=raspberry-pi-01

# how confident the model needs to be before accepting a scan result (between 0 and 1)
MIN_CONFIDENCE=0.80

